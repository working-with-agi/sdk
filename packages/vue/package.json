{
  "name": "@working-with-agi/vue",
  "version": "0.3.0",
  "description": "WorkWithAGI Vue 3 components — AI Terminal",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly --outDir dist",
    "dev": "vite build --watch",
    "clean": "rm -rf dist",
    "lint": "vue-tsc --noEmit",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "@working-with-agi/sdk": "workspace:*",
    "reconnecting-websocket": "^4.4.0"
  },
