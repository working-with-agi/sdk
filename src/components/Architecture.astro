---
import type { Lang } from '@/i18n/ui';
import { content } from '@/i18n/content';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const a = content[lang].architecture;
const isJa = lang === 'ja';

const colorMap: Record<string, { bg: string; border: string; text: string; dot: string }> = {
  accent: { bg: 'bg-accent/5', border: 'border-accent/20', text: 'text-accent', dot: 'bg-accent' },
  teal: { bg: 'bg-teal-50', border: 'border-teal-200', text: 'text-teal-700', dot: 'bg-teal-500' },
  purple: { bg: 'bg-purple-50', border: 'border-purple-200', text: 'text-purple-700', dot: 'bg-purple-500' },
  blue: { bg: 'bg-blue-50', border: 'border-blue-200', text: 'text-blue-700', dot: 'bg-blue-500' },
};
---

<section id="architecture" class="py-[clamp(80px,12vw,140px)] bg-paper-alt">
  <div class="max-w-[1140px] mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="reveal inline-block text-xs font-semibold tracking-wider uppercase text-accent mb-4">{a.eyebrow}</p>
      <h2 class="reveal font-display text-[clamp(24px,3.5vw,40px)] font-bold tracking-tight leading-snug mb-4">
        {a.title}
      </h2>
      <p class="reveal text-text-secondary">{a.subtitle}</p>
    </div>

    <!-- Architecture layers -->
    <div class="reveal max-w-2xl mx-auto space-y-4 mb-16">
      {a.layers.map((layer, i) => {
        const c = colorMap[layer.color] || colorMap.accent;
        return (
          <div class={`rounded-2xl border ${c.border} ${c.bg} p-6 transition-all hover:shadow-md`}>
            <div class="flex items-start gap-4">
              <div class="flex flex-col items-center gap-1 pt-1">
                <div class={`w-3 h-3 rounded-full ${c.dot}`} />
                {i < a.layers.length - 1 && (
                  <div class="w-px h-8 bg-border-soft" />
                )}
              </div>
              <div>
                <h3 class={`font-display font-semibold ${c.text}`}>{layer.label}</h3>
                <p class="mt-1 text-sm text-text-secondary leading-relaxed">{layer.desc}</p>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    <!-- Adoptions -->
    {a.adoptions.length > 0 && (
      <div class="reveal max-w-2xl mx-auto">
        <h3 class="text-center text-sm font-semibold text-text-muted uppercase tracking-wider mb-6">
          {isJa ? 'Aether Platform 上のサービス' : 'Services on Aether Platform'}
        </h3>
        <div class="grid gap-4">
          {a.adoptions.map((item) => (
            <a
              href={item.url}
              target="_blank"
              rel="noopener"
              class="flex items-center gap-4 rounded-xl border border-border-soft bg-white p-5 transition-all hover:border-accent hover:shadow-md"
            >
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-accent-light text-accent font-display font-bold text-sm">
                {item.name.charAt(0)}
              </div>
              <div>
                <div class="font-semibold text-text-primary text-sm">{item.name}</div>
                <div class="text-xs text-text-secondary mt-0.5">{item.desc}</div>
              </div>
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="ml-auto w-4 h-4 shrink-0 text-text-muted">
                <path d="M6 3l5 5-5 5" />
              </svg>
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>
