  review: 'M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z',
  exec: 'M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941',
};
---

<section id="use-cases" class="py-[clamp(80px,12vw,140px)] bg-paper-alt/50">
  <div class="max-w-[1140px] mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="reveal inline-block text-xs font-semibold tracking-wider uppercase text-accent mb-4">{u.eyebrow}</p>
      <h2 class="reveal font-display text-[clamp(24px,3.5vw,40px)] font-bold tracking-tight leading-snug">
        {u.title}
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {u.items.map((item) => (
        <div class="reveal rounded-2xl border border-border-soft bg-white p-6 flex gap-4">
          <div class="shrink-0 flex items-start justify-center w-10 h-10 rounded-xl bg-accent-light text-accent pt-2">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconMap[item.icon] || iconMap.dashboard} />
            </svg>
          </div>
          <div>
            <h3 class="font-display font-semibold text-text-primary mb-1">{item.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
