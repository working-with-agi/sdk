---
import type { Lang } from '@/i18n/ui';
import { content } from '@/i18n/content';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const d = content[lang].demo;
---

<section id="demo" class="py-[clamp(80px,12vw,140px)] bg-paper-alt/50">
  <div class="max-w-[1140px] mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <p class="reveal inline-block text-xs font-semibold tracking-wider uppercase text-accent mb-4">{d.eyebrow}</p>
      <h2 class="reveal font-display text-[clamp(24px,3.5vw,40px)] font-bold tracking-tight leading-snug mb-4">
        {d.title}
      </h2>
      <p class="reveal text-text-secondary">{d.subtitle}</p>
    </div>

    <!-- Live terminal demo -->
    <div class="reveal max-w-3xl mx-auto">
      <div
        id="demo-widget"
        class="rounded-2xl border border-border-soft bg-[#1e1e1e] shadow-[0_8px_40px_rgba(124,58,237,0.1)] overflow-hidden"
        data-lang={lang}
        data-agent-url={import.meta.env.PUBLIC_AGENT_SERVER_URL || 'wss://agent.workwithagi.dev'}
      >
        <!-- Widget header -->
        <div class="flex items-center gap-3 px-4 py-3 border-b border-white/10 bg-[#2a2a3e]">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-accent text-white">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="w-4 h-4">
              <path d="M8 2v4M8 10v4M2 8h4M10 8h4M4 4l2.5 2.5M9.5 9.5L12 12M12 4l-2.5 2.5M6.5 9.5L4 12" />
            </svg>
          </div>
          <div>
            <div class="text-sm font-semibold text-white/90">Work with AI</div>
            <div id="demo-status" class="text-[11px] text-white/40 flex items-center gap-1">
              <span id="demo-dot" class="w-1.5 h-1.5 rounded-full bg-white/40"></span>
              {lang === 'ja' ? '接続中...' : 'Connecting...'}
            </div>
          </div>
          <div class="ml-auto flex items-center gap-1.5">
            <div class="w-2.5 h-2.5 rounded-full bg-red-400/60"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/60"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-green-400/60"></div>
          </div>
        </div>

        <!-- Terminal container -->
        <div id="demo-terminal" class="h-[420px]"></div>

        <!-- Suggestion bar -->
        <div class="border-t border-white/10 bg-[#2a2a3e] px-4 py-2.5">
          <div class="flex flex-wrap gap-2">
            {d.suggestions.map((s) => (
              <button
                class="demo-suggestion rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-[11px] text-white/60 transition-all hover:border-accent/50 hover:text-accent hover:bg-accent/10"
                data-text={s}
              >
                {s}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  async function initDemo() {
    const widget = document.getElementById('demo-widget');
    if (!widget) return;

    const agentUrl = widget.dataset.agentUrl || 'wss://agent.workwithagi.dev';
    const lang = widget.dataset.lang || 'ja';
    const terminalEl = document.getElementById('demo-terminal')!;
    const statusEl = document.getElementById('demo-status')!;
    const dotEl = document.getElementById('demo-dot')!;

    // Dynamic import xterm.js
    const [{ Terminal }, { FitAddon }, { WebLinksAddon }] = await Promise.all([
      import('https://esm.sh/@xterm/xterm@5.5.0'),
      import('https://esm.sh/@xterm/addon-fit@0.10.0'),
      import('https://esm.sh/@xterm/addon-web-links@0.11.0'),
    ]);

    // Load xterm CSS
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://esm.sh/@xterm/xterm@5.5.0/css/xterm.css';
    document.head.appendChild(link);

    const terminal = new Terminal({
      convertEol: true,
      cursorBlink: true,
      disableStdin: false,
      scrollback: 5000,
      theme: {
        background: '#1e1e1e',
        foreground: '#ffffff',
        cursor: '#ffffff',
        cursorAccent: '#000000',
        selectionBackground: 'rgba(255, 255, 255, 0.3)',
      },
      allowProposedApi: true,
      fontSize: 13,
      fontFamily: "'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace",
    });

    const fitAddon = new FitAddon();
    terminal.loadAddon(fitAddon);
    terminal.loadAddon(new WebLinksAddon());
    terminal.open(terminalEl);
    fitAddon.fit();

    const resizeObserver = new ResizeObserver(() => fitAddon.fit());
    resizeObserver.observe(terminalEl);

    // Status helpers
    function setStatus(text: string, active: boolean) {
      statusEl.innerHTML = '';
      dotEl.className = `w-1.5 h-1.5 rounded-full ${active ? 'bg-green-400' : 'bg-white/40'}`;
      statusEl.appendChild(dotEl);
      statusEl.appendChild(document.createTextNode(' ' + text));
    }

    // WebSocket connection
    let paneId = '';
    let ws: WebSocket | null = null;
    let reconnectTimer: ReturnType<typeof setTimeout> | null = null;

    function connect() {
      const url = `${agentUrl}/ws/tmux/work-with-ai`;
      ws = new WebSocket(url);
      ws.binaryType = 'arraybuffer';

      ws.onopen = () => {
        setStatus(lang === 'ja' ? '接続済み' : 'Connected', true);
        // Request session
        ws?.send(JSON.stringify({
          type: 'create_session',
          payload: {
            api_key: 'demo',
            skills: [],
            context: { demo: true },
            locale: lang,
          },
        }));
      };

      ws.onmessage = (event: MessageEvent) => {
        if (typeof event.data === 'string') {
          try {
            const msg = JSON.parse(event.data);
            if (msg.type === 'state_sync' || msg.type === 'session_created') {
              const session = msg.session || msg;
              if (session.panes && session.panes.length > 0) {
                paneId = session.panes[0].pane_id || '';
              }
              setStatus(lang === 'ja' ? 'セッション中' : 'Session active', true);
            }
            if (msg.type === 'pane_exited') {
              setStatus(lang === 'ja' ? '接続済み' : 'Connected', true);
            }
          } catch { /* ignore */ }
        } else {
          // Binary frame: [1 byte pane_id_len][pane_id][pty data]
          const view = new Uint8Array(event.data as ArrayBuffer);
          if (view.length < 2) return;
          const paneIdLen = view[0];
          if (view.length < 1 + paneIdLen) return;
          terminal.write(view.slice(1 + paneIdLen));
        }
      };

      ws.onclose = () => {
        setStatus(lang === 'ja' ? '再接続中...' : 'Reconnecting...', false);
        reconnectTimer = setTimeout(connect, 3000);
      };

      ws.onerror = () => {
        setStatus(lang === 'ja' ? '接続エラー' : 'Connection error', false);
      };
    }

    // Send input to PTY
    function sendInput(data: string) {
      if (!ws || ws.readyState !== WebSocket.OPEN || !paneId) return;
      const paneBytes = new TextEncoder().encode(paneId);
      const dataBytes = new TextEncoder().encode(data);
      const frame = new Uint8Array(1 + paneBytes.length + dataBytes.length);
      frame[0] = paneBytes.length;
      frame.set(paneBytes, 1);
      frame.set(dataBytes, 1 + paneBytes.length);
      ws.send(frame.buffer);
    }

    function sendResize(cols: number, rows: number) {
      if (!ws || ws.readyState !== WebSocket.OPEN || !paneId) return;
      ws.send(JSON.stringify({ type: 'pane_resize', pane_id: paneId, cols, rows }));
    }

    terminal.onData((data: string) => sendInput(data));
    terminal.onResize(({ cols, rows }) => sendResize(cols, rows));

    // Suggestion buttons: type text into terminal
    document.querySelectorAll('.demo-suggestion').forEach(btn => {
      btn.addEventListener('click', () => {
        const text = (btn as HTMLElement).dataset.text || '';
        sendInput(text + '\r');
        terminal.focus();
      });
    });

    // Connect
    connect();
  }

  // Init when DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDemo);
  } else {
    initDemo();
  }
</script>
