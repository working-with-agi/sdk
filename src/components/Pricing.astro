---
import type { Lang } from '@/i18n/ui';
import { content } from '@/i18n/content';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const p = content[lang].pricing;
const isJa = lang === 'ja';
---

<section id="pricing" class="py-[clamp(80px,12vw,140px)]">
  <div class="max-w-[1140px] mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto">
      <p class="reveal inline-block text-xs font-semibold tracking-wider uppercase text-accent mb-4">{p.eyebrow}</p>
      <h2 class="reveal font-display text-[clamp(24px,3.5vw,40px)] font-bold tracking-tight leading-snug mb-4">
        {p.title}
      </h2>
      <p class="reveal text-text-secondary mb-8">{p.subtitle}</p>
      <a
        href="#cta-section"
        class="reveal inline-flex items-center justify-center px-6 py-3 bg-accent hover:bg-accent-hover text-white font-medium rounded-xl transition-colors text-sm"
      >
        {isJa ? 'お問い合わせ' : 'Contact us'}
      </a>
    </div>
  </div>
</section>
