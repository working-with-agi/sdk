---
import type { Lang } from '@/i18n/ui';
import { content } from '@/i18n/content';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const f = content[lang].features;

const iconMap: Record<string, string> = {
  risk: 'M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z',
  progress: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z',
  compare: 'M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5',
  action: 'M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z',
  timeline: 'M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5',
  chat: 'M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z',
};

const colorMap: Record<string, { bg: string; text: string }> = {
  risk: { bg: 'bg-red-50', text: 'text-red-600' },
  progress: { bg: 'bg-blue-50', text: 'text-blue-600' },
  compare: { bg: 'bg-teal-light', text: 'text-teal' },
  action: { bg: 'bg-amber-50', text: 'text-amber-600' },
  timeline: { bg: 'bg-purple-50', text: 'text-accent' },
  chat: { bg: 'bg-accent-light', text: 'text-accent' },
};
---

<section id="features" class="py-[clamp(80px,12vw,140px)]">
  <div class="max-w-[1140px] mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="reveal inline-block text-xs font-semibold tracking-wider uppercase text-accent mb-4">{f.eyebrow}</p>
      <h2 class="reveal font-display text-[clamp(24px,3.5vw,40px)] font-bold tracking-tight leading-snug mb-4">
        {f.title}
      </h2>
      <p class="reveal text-text-secondary">{f.subtitle}</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {f.cards.map((card) => {
        const color = colorMap[card.icon] || colorMap.chat;
        const icon = iconMap[card.icon] || iconMap.chat;
        return (
          <div class="reveal group rounded-2xl border border-border-soft bg-white p-6 transition-all hover:shadow-[0_4px_20px_rgba(124,58,237,0.08)] hover:border-accent/20">
            <div class={`inline-flex items-center justify-center w-10 h-10 rounded-xl ${color.bg} ${color.text} mb-4`}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
              </svg>
            </div>
            <h3 class="font-display font-semibold text-text-primary mb-2">{card.title}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{card.desc}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>
